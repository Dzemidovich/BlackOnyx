# Пример файла с переменными окружения для production
# Скопируй этот файл и заполни реальными значениями
# НЕ КОММИТЬ ФАЙЛ С РЕАЛЬНЫМИ ДАННЫМИ В GIT!

# ============================================
# БАЗА ДАННЫХ
# ============================================
ConnectionStrings__DefaultConnection="Host=YOUR_DB_HOST;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SSL Mode=Require"

# Примеры для разных хостингов:
# Azure: Host=yourserver.postgres.database.azure.com;Database=toolshopdb;Username=admin@yourserver;Password=...;SSL Mode=Require
# DigitalOcean: Host=db-postgresql-nyc3-12345.ondigitalocean.com;Database=toolshopdb;Username=doadmin;Password=...;SSL Mode=Require;Port=25060
# AWS RDS: Host=yourdb.123456.us-east-1.rds.amazonaws.com;Database=toolshopdb;Username=postgres;Password=...;SSL Mode=Require

# ============================================
# JWT НАСТРОЙКИ - КРИТИЧНО ДЛЯ БЕЗОПАСНОСТИ!
# ============================================
JWT_SECRET_KEY="YOUR_STRONG_SECRET_KEY_MINIMUM_32_CHARACTERS_LONG_GENERATED_BY_SCRIPT"
JWT_ISSUER="ToolShop"
JWT_AUDIENCE="ToolShopUsers"

# ВАЖНО: Сгенерируй случайный ключ минимум 256 бит (32 байта)
# Windows PowerShell: .\generate_jwt_key.ps1
# Linux/Mac: openssl rand -base64 32
# Или онлайн: https://generate-random.org/api-token-generator?count=1&length=64

# ============================================
# CORS (Разрешенные домены)
# ============================================
AllowedOrigins__0="https://yourdomain.com"
AllowedOrigins__1="https://www.yourdomain.com"

# Для поддоменов:
# AllowedOrigins__2="https://api.yourdomain.com"

# ============================================
# ОКРУЖЕНИЕ
# ============================================
ASPNETCORE_ENVIRONMENT="Production"

# ============================================
# ПОРТ (опционально)
# ============================================
# Некоторые хостинги требуют определенный порт
# PORT=5000

# ============================================
# HTTPS (опционально)
# ============================================
# Если хостинг сам управляет SSL (например, через reverse proxy)
# DISABLE_HTTPS_REDIRECT="true"

# ============================================
# ЛОГИРОВАНИЕ (опционально)
# ============================================
# Logging__LogLevel__Default="Warning"
# Logging__LogLevel__Microsoft.AspNetCore="Warning"

# ============================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ (опционально)
# ============================================
# Таймзона
# TZ="Europe/Minsk"

# Культура
# ASPNETCORE_CULTURE="ru-RU"

# ============================================
# ИНСТРУКЦИИ
# ============================================
# 1. Скопируй этот файл: cp .env.example .env
# 2. Заполни реальными значениями
# 3. НЕ ДОБАВЛЯЙ .env В GIT!
# 4. На хостинге установи эти переменные через панель управления

# ============================================
# ПРОВЕРКА
# ============================================
# После установки переменных проверь:
# - Приложение запускается без ошибок
# - Подключение к БД работает
# - JWT токены генерируются
# - CORS не блокирует запросы
